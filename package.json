{
  "name": "playwright-poc",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-init.ts",
    "test:monitoring:db": "playwright test tests/homepage.monitor.spec.ts tests/critical-paths.monitor.spec.ts --project=chromium-core",
    "test:enrollmate": "playwright test --config=playwright.enrollmate.config.ts",
    "report:enrollmate": "playwright show-report playwright-report-enrollmate",
    "report": "playwright show-report",
    "allure:db": "tsx scripts/allure-from-db.ts && node scripts/allure.cjs generate ./allure-results-db -o ./allure-report-db --clean",
    "allure:open:db": "node scripts/allure.cjs open ./allure-report-db",
    "allure:generate": "node scripts/allure.cjs generate ./allure-results -o ./allure-report --clean",
    "allure:open": "node scripts/allure.cjs open ./allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.15.6",
    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.8.0",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
