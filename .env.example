DATABASE_URL=postgres://test:test@localhost:5432/playwright

# Local Docker PostgreSQL settings only.
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=playwright

# Enable DB-backed Playwright result persistence.
PW_DB_ENABLED=false
PW_DB_REPORTER_STRICT=false
PW_RUN_ENV=local

# Control-plane monitoring settings.
TARGET_BASE_URL=https://www.mmdc.mcl.edu.ph/
CONTROL_PLANE_INTERVAL_MS=900000
